{
  "name": "vscode-live2d-pet",
  "displayName": "VSCode Live2D Pet",
  "description": "Live2D pet for VS Code.",
  "version": "0.0.1",
  "publisher": "yourname",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onView:live2dView",
    "onStartupFinished",
    "onCommand:vscode-live2d-pet.toggle",
    "onCommand:vscode-live2d-pet.selectModel"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "live2d-pet",
          "title": "Live2D Pet",
          "icon": "resources/heart.svg"
        }
      ]
    },
    "views": {
      "live2d-pet": [
        {
          "id": "live2dView",
          "name": "Live2D Pet",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-live2d-pet.toggle",
        "title": "Toggle Live2D Pet"
      },
      {
        "command": "vscode-live2d-pet.selectModel",
        "title": "Select Live2D Model"
      },
      {
        "command": "vscode-live2d-pet.openWebviewDevTools",
        "title": "Open Live2D Webview DevTools"
      }
    ],
    "configuration": {
      "title": "VSCode Live2D Pet",
      "properties": {
        "vscode-live2d-pet.selectedModel": {
          "type": "string",
          "default": "haru/haru01.model.json",
          "description": "Relative model path under resources/live2d. Use command 'Select Live2D Model' to switch from discovered models."
        }
      }
    },
    "keybindings": [
      {
        "command": "vscode-live2d-pet.toggle",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      },
      {
        "command": "vscode-live2d-pet.selectModel",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      }
    ]
  },
  "devDependencies": {
    "live2dcubismcore": "^1.0.2",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10"
  }
}
