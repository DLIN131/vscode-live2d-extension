{
  "name": "vscode-live2d-pet",
  "displayName": "VSCode Live2D Pet",
  "description": "在 VSCode 嵌入 Live2D 看板娘",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "live2d-pet",
          "title": "Live2D 看板娘",
          "icon": "resources/heart.svg"
        }
      ]
    },
    "views": {
      "live2d-pet": [
        {
          "id": "live2dView",
          "name": "我的看板娘",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-live2d-pet.toggle",
        "title": "切換看板娘顯示/隱藏"
      },
      {
        "command": "vscode-live2d-pet.randomModel",
        "title": "換一個看板娘"
      }
    ],
    "keybindings": [
      {
        "command": "vscode-live2d-pet.toggle",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "activationEvents": [
    "onView:live2dView",
    "onCommand:vscode-live2d-pet.toggle",
    "onCommand:vscode-live2d-pet.randomModel"
  ]
}
